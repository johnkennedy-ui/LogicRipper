<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logic Ripper" Height="720" Width="1040" MinHeight="620" MinWidth="920">
  <DockPanel>
    <StatusBar DockPanel.Dock="Bottom">
      <TextBlock Name="StatusText" Text="Ready" />
      <ProgressBar Name="Progress" Width="180" Height="14" Minimum="0" Maximum="100" Value="0" Margin="16,0,0,0"/>
    </StatusBar>

    <Grid Margin="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="210"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border BorderBrush="#cbd5e1" BorderThickness="1" Padding="10" Background="#f8fafc">
        <StackPanel>
          <TextBlock Text="Logic Ripper" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14"/>
          <RadioButton Name="StepInput" Content="1. Input code view" IsChecked="True" Margin="0,0,0,10"/>
          <RadioButton Name="StepTemplate" Content="2. Review template" Margin="0,0,0,10"/>
          <RadioButton Name="StepWorkspace" Content="3. Pick workspace" Margin="0,0,0,10"/>
          <RadioButton Name="StepValues" Content="4. Enter missing value" Margin="0,0,0,10"/>
          <RadioButton Name="StepExport" Content="5. Export code view" Margin="0,0,0,18"/>
          <Separator Margin="0,0,0,12"/>
          <Button Name="BackButton" Content="Back" Height="30" Margin="0,0,0,6"/>
          <Button Name="NextButton" Content="Next" Height="30"/>
        </StackPanel>
      </Border>

      <TabControl Name="Tabs" Grid.Column="1" Margin="10,0,0,0">
        <TabItem Header="1 Input">
          <Grid Margin="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel>
              <TextBlock Text="Input Logic App code view" FontSize="20" FontWeight="SemiBold"/>
              <TextBlock Text="Choose one exported Logic App workflow JSON file. Sanitisation runs before anything is saved." Margin="0,6,0,12"/>
              <Button Name="ImportTemplateButton" Content="Choose code-view JSON" Width="170" HorizontalAlignment="Left"/>
            </StackPanel>
            <TextBox Name="InputPreviewText" Grid.Row="1" Margin="0,12,0,12" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
            <TextBlock Grid.Row="2" Text="Result: sanitised template is stored in the local library and can be renamed or versioned later."/>
          </Grid>
        </TabItem>

        <TabItem Header="2 Template">
          <Grid Margin="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel>
              <TextBlock Text="Review the template just imported" FontSize="20" FontWeight="SemiBold"/>
              <TextBlock Text="The imported code-view JSON is now a reusable sanitised template. Rename it here if needed." Margin="0,6,0,12"/>
            </StackPanel>
            <Grid Grid.Row="1" Margin="0,0,0,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="Template name" VerticalAlignment="Center"/>
              <TextBox Name="TemplateNameText" Grid.Column="1" Height="30" Margin="0,0,8,0"/>
              <Button Name="RenameTemplateButton" Grid.Column="2" Content="Save name"/>
            </Grid>
            <DataGrid Name="TemplateGrid" Grid.Row="2" AutoGenerateColumns="False" SelectionMode="Single" IsReadOnly="True">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Template" Binding="{Binding displayName}" Width="180"/>
                <DataGridTextColumn Header="Description" Binding="{Binding description}" Width="250"/>
                <DataGridTextColumn Header="Category" Binding="{Binding category}" Width="140"/>
                <DataGridTextColumn Header="Trigger" Binding="{Binding triggerType}" Width="180"/>
                <DataGridTextColumn Header="Status" Binding="{Binding readinessStatus}" Width="130"/>
              </DataGrid.Columns>
            </DataGrid>
            <TextBlock Grid.Row="3" Text="No extra template selection is needed after import. This grid is only the library/history view." Margin="0,10,0,0"/>
          </Grid>
        </TabItem>

        <TabItem Header="3 Workspace">
          <Grid Margin="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel>
              <TextBlock Text="Pick or add one target workspace" FontSize="20" FontWeight="SemiBold"/>
              <TextBlock Text="Customer-wide values are saved here so they are not re-entered for every export." Margin="0,6,0,12"/>
            </StackPanel>
            <DataGrid Name="WorkspaceGrid" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single" IsReadOnly="True">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Workspace" Binding="{Binding displayName}" Width="190"/>
                <DataGridTextColumn Header="Tenant" Binding="{Binding tenantId}" Width="220"/>
                <DataGridTextColumn Header="Subscription" Binding="{Binding subscriptionId}" Width="220"/>
                <DataGridTextColumn Header="Resource group" Binding="{Binding resourceGroupName}" Width="170"/>
                <DataGridTextColumn Header="Runtime identity" Binding="{Binding defaultLogicAppRuntimeIdentity.type}" Width="130"/>
              </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
              <Button Name="AddWorkspaceButton" Content="Add workspace" Width="120" Margin="0,0,6,0"/>
              <Button Name="EditWorkspaceButton" Content="Edit selected" Width="110"/>
            </StackPanel>
          </Grid>
        </TabItem>

        <TabItem Header="4 Values">
          <Grid Margin="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Enter one missing value" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1" Name="ValueGuideText" Text="The guide shows where to get the current value. Saved workspace values are skipped." Margin="0,6,0,12"/>
            <Grid Grid.Row="2">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <TextBlock Name="CurrentValueLabel" Text="Value name" FontWeight="SemiBold"/>
              <TextBox Name="CurrentValueText" Grid.Row="1" Height="30" Margin="0,6,0,10"/>
              <TextBox Name="MissingValuesText" Grid.Row="2" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
            </Grid>
            <Button Name="SaveBindingButton" Grid.Row="3" Content="Save value and continue" Width="160" HorizontalAlignment="Right" Margin="0,10,0,0"/>
          </Grid>
        </TabItem>

        <TabItem Header="5 Export">
          <Grid Margin="12">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Export code-view JSON" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock Grid.Row="1" Text="Review the selected template, workspace and saved values. Export writes codeview.json only." Margin="0,6,0,12"/>
            <TextBox Name="ValidationSummaryText" Grid.Row="2" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
              <TextBox Name="OutputFolderText" Width="420" Margin="0,0,8,0"/>
              <Button Name="GeneratePackageButton" Content="Export code view" Width="140" Margin="0,0,6,0"/>
              <Button Name="OpenOutputButton" Content="Open folder" Width="100"/>
            </StackPanel>
          </Grid>
        </TabItem>

        <TabItem Header="Activity">
          <TextBox Name="ActivityLog" Margin="12" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True"/>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>
</Window>
