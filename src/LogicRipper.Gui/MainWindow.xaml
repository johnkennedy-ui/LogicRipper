<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Logic Ripper" Height="720" Width="1040" MinHeight="620" MinWidth="920">
  <DockPanel>
    <StatusBar DockPanel.Dock="Bottom">
      <TextBlock Name="StatusText" Text="Ready" />
    </StatusBar>
    <Grid Margin="10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="210"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Border BorderBrush="#cbd5e1" BorderThickness="1" Padding="10" Background="#f8fafc">
        <StackPanel>
          <TextBlock Text="Logic Ripper" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14"/>
          <RadioButton Content="Start" IsChecked="True" Margin="0,0,0,10"/>
          <RadioButton Content="1. Paste code view" Margin="0,0,0,10"/>
          <RadioButton Content="2. Review values" Margin="0,0,0,10"/>
          <RadioButton Content="3. Template" Margin="0,0,0,10"/>
          <RadioButton Content="4. Workspace" Margin="0,0,0,10"/>
          <RadioButton Content="5. Generate JSON" Margin="0,0,0,18"/>
          <Separator Margin="0,0,0,12"/>
          <Button Name="BackButton" Content="Back" Height="30" Margin="0,0,0,6"/>
          <Button Name="NextButton" Content="Next" Height="30"/>
        </StackPanel>
      </Border>
      <TabControl Name="Tabs" Grid.Column="1" Margin="10,0,0,0">
        <TabItem Header="Start">
          <Grid Margin="12">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <StackPanel>
              <TextBlock Text="Choose the workflow" FontSize="22" FontWeight="SemiBold"/>
              <TextBlock Text="Import creates a reusable template from pasted code-view JSON. Export uses saved templates and saved workspaces without pasting anything new." Margin="0,6,0,22"/>
              <UniformGrid Columns="2">
                <Button Name="StartImportButton" Content="Import new template" Height="90" Margin="0,0,10,0"/>
                <Button Name="StartExportButton" Content="Export saved template" Height="90" Margin="10,0,0,0"/>
              </UniformGrid>
            </StackPanel>
          </Grid>
        </TabItem>
        <TabItem Header="1 Paste">
          <Grid Margin="12">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel>
              <TextBlock Text="Paste Logic App code-view JSON" FontSize="20" FontWeight="SemiBold"/>
              <TextBlock Text="Paste one workflow definition from Logic App code view, then click Analyse." Margin="0,6,0,12"/>
            </StackPanel>
            <TextBox Name="CodeViewText" Grid.Row="1" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas"/>
            <Button Name="AnalyseButton" Grid.Row="2" Content="Analyse" Width="110" HorizontalAlignment="Right" Margin="0,10,0,0"/>
          </Grid>
        </TabItem>
        <TabItem Header="2 Values">
          <Grid Margin="12">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel>
              <TextBlock Text="Review detected values" FontSize="20" FontWeight="SemiBold"/>
              <TextBlock Text="Mark each value as replace, preserve, or secret / do not export. Generation is blocked until every value is reviewed." Margin="0,6,0,12"/>
            </StackPanel>
            <DataGrid Name="FindingsGrid" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Path" Binding="{Binding path}" Width="220"/>
                <DataGridTextColumn Header="Value" Binding="{Binding value}" Width="240"/>
                <DataGridTextColumn Header="Kind" Binding="{Binding kind}" Width="90"/>
                <DataGridTextColumn Header="Decision" Binding="{Binding decision}" Width="100"/>
                <DataGridTextColumn Header="Replacement name" Binding="{Binding replacementName}" Width="170"/>
              </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
              <Button Name="MarkReplaceButton" Content="Replace" Width="90" Margin="0,0,6,0"/>
              <Button Name="MarkPreserveButton" Content="Preserve" Width="90" Margin="0,0,6,0"/>
              <Button Name="MarkSecretButton" Content="Secret" Width="90"/>
            </StackPanel>
          </Grid>
        </TabItem>
        <TabItem Header="3 Template">
          <Grid Margin="12">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <TextBlock Text="Save reusable template" FontSize="20" FontWeight="SemiBold"/>
            <Grid Grid.Row="1" Margin="0,12,0,12">
              <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions>
              <TextBlock Text="Template name" VerticalAlignment="Center"/>
              <TextBox Name="TemplateNameText" Grid.Column="1" Height="30" Margin="0,0,8,0"/>
              <Button Name="SaveTemplateButton" Grid.Column="2" Content="Save"/>
            </Grid>
            <DataGrid Name="TemplateGrid" Grid.Row="2" AutoGenerateColumns="False" SelectionMode="Single" IsReadOnly="True">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Template" Binding="{Binding name}" Width="230"/>
                <DataGridTextColumn Header="Purpose" Binding="{Binding purpose}" Width="360"/>
                <DataGridTextColumn Header="Saved" Binding="{Binding savedAt}" Width="180"/>
              </DataGrid.Columns>
            </DataGrid>
            <TextBlock Grid.Row="3" Text="In import mode, the template just saved is selected automatically. In export mode, select one saved template here." Margin="0,10,0,0"/>
          </Grid>
        </TabItem>
        <TabItem Header="4 Workspace">
          <Grid Margin="12">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <TextBlock Text="Pick or add target workspace values" FontSize="20" FontWeight="SemiBold"/>
            <Grid Grid.Row="1" Margin="0,12,0,12">
              <Grid.ColumnDefinitions><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/><ColumnDefinition Width="90"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
              <TextBlock Text="Workspace name" VerticalAlignment="Center"/>
              <TextBox Name="WorkspaceNameText" Grid.Column="1" Height="30" Margin="0,0,8,0"/>
              <Button Name="AddWorkspaceButton" Grid.Column="2" Content="Add workspace" Margin="0,0,6,0"/>
              <Button Name="EditWorkspaceButton" Grid.Column="3" Content="Edit" Margin="0,0,6,0"/>
              <Button Name="SaveWorkspaceButton" Grid.Column="4" Content="Save"/>
            </Grid>
            <DataGrid Name="WorkspaceGrid" Grid.Row="2" AutoGenerateColumns="False" SelectionMode="Single" IsReadOnly="True">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Workspace" Binding="{Binding displayName}" Width="220"/>
                <DataGridTextColumn Header="Saved" Binding="{Binding savedAt}" Width="180"/>
              </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="3" Margin="0,10,0,0">
              <TextBlock Text="Enter one reusable workspace value at a time, then save the profile."/>
              <DockPanel Margin="0,6,0,0">
                <TextBox Name="WorkspaceValueNameText" Width="210" Margin="0,0,6,0" ToolTip="Value name, e.g. tenantId"/>
                <TextBox Name="WorkspaceValueText" Width="360" Margin="0,0,6,0" ToolTip="Value"/>
                <Button Name="AddWorkspaceValueButton" Content="Add value" Width="95"/>
              </DockPanel>
              <TextBox Name="WorkspaceValuesPreviewText" Height="70" AcceptsReturn="True" IsReadOnly="True" Margin="0,6,0,0"/>
            </StackPanel>
          </Grid>
        </TabItem>
        <TabItem Header="5 Generate">
          <Grid Margin="12">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel>
              <TextBlock Text="Generate target code-view JSON" FontSize="20" FontWeight="SemiBold"/>
              <TextBlock Text="Save values that belong to this template and workspace, such as notificationEmail and connector reference mappings. Enter one value at a time." Margin="0,6,0,10"/>
            </StackPanel>
            <StackPanel Grid.Row="1">
              <DockPanel>
                <TextBox Name="BindingValueNameText" Width="220" Margin="0,0,6,0" ToolTip="Value name, e.g. notificationEmail or sentinelConnectionId"/>
                <TextBox Name="BindingValueText" Width="430" Margin="0,0,6,0" ToolTip="Value or Manual edit required"/>
                <Button Name="AddBindingValueButton" Content="Add value" Width="95" Margin="0,0,6,0"/>
                <Button Name="SaveBindingButton" Content="Save binding" Width="105"/>
              </DockPanel>
              <TextBox Name="BindingValuesPreviewText" Height="58" AcceptsReturn="True" IsReadOnly="True" Margin="0,6,0,0"/>
            </StackPanel>
            <TextBox Name="GeneratedCodeViewText" Grid.Row="2" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" IsReadOnly="True" Margin="0,12,0,0"/>
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
              <Button Name="GenerateButton" Content="Generate" Width="110" Margin="0,0,6,0"/>
              <Button Name="CopyButton" Content="Copy JSON" Width="110" Margin="0,0,6,0"/>
              <Button Name="OpenOutputButton" Content="Open folder" Width="110"/>
            </StackPanel>
          </Grid>
        </TabItem>
        <TabItem Header="Activity">
          <TextBox Name="ActivityLog" Margin="12" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True"/>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>
</Window>
